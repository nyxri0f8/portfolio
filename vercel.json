{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": "(?i).*httrack.*|.*wget.*|.*scra.*|.*extract.*|.*copier.*|.*offline.*|.*cyberduck.*|.*teleport.*|.*webcopy.*"
        }
      ],
      "destination": "https://httpbin.org/status/403",
      "permanent": false
    }
  ]
}
